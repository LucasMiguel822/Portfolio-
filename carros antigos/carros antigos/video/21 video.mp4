o deixa com a gente.\n_______________________________\n#porsche #911 #supercar #carspotting #carporn","delight_ranges":[],"image_ranges":[],"inline_style_ranges":[],"aggregated_ranges":[],"ranges":[{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/porsche?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/porsche","__isNode":"Hashtag","id":"459153237491470"},"entity_is_weak_reference":false,"length":8,"offset":510},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/supercar?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/supercar","__isNode":"Hashtag","id":"577718992238257"},"entity_is_weak_reference":false,"length":9,"offset":524},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/carspotting?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/carspotting","__isNode":"Hashtag","id":"564636930222376"},"entity_is_weak_reference":false,"length":12,"offset":534},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/carporn?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/carporn","__isNode":"Hashtag","id":"495529730503497"},"entity_is_weak_reference":false,"length":8,"offset":547}],"color_ranges":[]},"id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxMTYxNzMxMjEyNzA3MTM4"},"live_status":"NEVER_LIVE","owner":{"__typename":"User","__isVideoOwner":"User","owner_as_page":{"name":"Via Bella Ve\u00edculos","id":"201008879940077"},"id":"100064405340960"}},"extensions":{"prefetch_uris_v2":[{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t39.30808-1\/252343281_6621399317900969_3803204123193148195_n.png?stp=cp0_dst-png_s40x40&_nc_cat=107&ccb=1-7&_nc_sid=2d3e12&_nc_ohc=WBHNRYO4cOAQ7kNvwEdx5Gx&_nc_oc=Ado2JKQr6JXm4CV1xpk5rrKDr-95zLqE7akZARWAe_3cSSiWn7BAh-Q8UWppr4IhOc8&_nc_zt=24&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfxA1