29287710803_n.jpg?stp=dst-jpg_p206x206_tt6&_nc_cat=107&ccb=1-7&_nc_sid=5fad0e&_nc_ohc=FRF6Q5j-uLgQ7kNvwF-gcYV&_nc_oc=AdoT0fECN7CExojC2ezLfua46lET5PUlBgs7CJVAaGIa9optE9yjVcb4EvuMpsvi1MQ&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfzI68Yq-V9txLPlNKiLrtC1bhcu9TI0yUsXfQv9GE9zLg&oe=69C9D5DE"},"is_video_broadcast":false,"has_viewer_watched_show_video":false,"id":"1381200510474173","is_live_streaming":false,"owner":{"__typename":"User","id":"100064405340960","name":"Via Bella Ve\u00edculos","gender":"NEUTER","__isActor":"User","profile_picture":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t39.30808-1\/252343281_6621399317900969_3803204123193148195_n.png?stp=cp0_dst-png_s50x50&_nc_cat=107&ccb=1-7&_nc_sid=2d3e12&_nc_ohc=WBHNRYO4cOAQ7kNvwEdx5Gx&_nc_oc=Ado2JKQr6JXm4CV1xpk5rrKDr-95zLqE7akZARWAe_3cSSiWn7BAh-Q8UWppr4IhOc8&_nc_zt=24&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_Afytxhtd25I2aNRQmPjDRTvzT46TAkLo17iNmKVeJrbyjQ&oe=69C9D311"}},"canonical_uri_with_fallback":"https:\/\/www.facebook.com\/viabellaveiculos\/videos\/na-vers\u0025C3\u0025A3o-s-o-718-boxster-evolui-de-forma-significativa-sai-do-20-e-passa-ao-25-\/1381200510474173\/","cix_screen":null,"broadcast_status":null,"video_thumbnail_overlays_renderer":{"__typename":"VideoHomeVideoThumbnailOverlaysDefaultRenderer","video":{"has_viewer_watched_show_video":false,"playable_duration_in_ms":45115,"viewer_last_play_position_ms":null,"broadcast_status":null,"playable_duration":46,"id":"1381200510474173","product_tags":[]},"__module_operation_CometVideoHomeVideoThumbnail_video":{"__dr":"CometVideoHomeVideoThumbnailDefaultOverlays_video$normalization.graphql"},"__module_component_CometVideoHomeVideoThumbnail_video":{"__dr":"CometVideoHomeVideoThumbnailDefaultOverlays.react"}},"name":"","savable_description":{"text":"Na vers\u00e3o \u201cS\u201d, o 718 Boxster evolui de forma significativa: sai do 2.0 e passa ao 2.5 turbo, entregando 350 cv e uma condu\u00e7\u00e3o ainda mais esportiva e envolvente.\n\nEste exemplar se destaca pela configura\u00e7\u00e3o de cores impec\u00e1vel, branco com capota bord\u00f4 e interior bicolor em couro estendido preto e bord\u00f4, al\u00e9m do raro estado de conserva\u00e7\u00e3o: um ve\u00edculo com apenas 10.920 km rodados!\n\nConta com Sport Chrono, volante em Alc\u00e2ntara, seletor de modos de condu\u00e7\u00e3o no volante, bot\u00e3o de ajuste do ronco do escapamento, suspens\u00e3o PASM rebaixada em 20mm (original), rodas 20\u201d Carrera Classic, al\u00e9m de opcionais como sistema de som Bose e bancos 14 vias, formando um conjunto excepcional.\n\nPORSCHE BOXSTER S 2018 com APENAS 10.920Km!\n\nR$ 499.000,00\n\n*Fotos e infos completas em nosso site, LINK na BIO\n_______________________________\n\nVia Bella, h\u00e1 28 anos no mercado!\nO carro deixa com a gente.\n_______________________________\n#porsche #porscheboxster #boxster #718boxster #sportscar"},"__isNode":"Video","creation_story":{"click_tracking_linkshim_cb":"AT48rRAZ1tBSMTwMnRTjVe17T-34ekn8O8UxSWIyQ-ZpB4PabsHW-ltuwmKuwEewRE5YuJOgVs-ricFTb-Js1QAPIzSrOrcmhmuRTLt-rE_wpoxZge_xp4mvyLf9TXtL5BSaYAcP2OTvpHfr37Phi0fPWwLZXNYvTM1Y-8DDsod1I2OOtCAT","encrypted_click_tracking":"AZadsKjrpa1EM_PeFdPUO7EE_PLX-n-Z4TzetMW6sj0K8PKlr35QPAidgHvyCS0B_lHqTZUidEWtszVsXmkyPKNQ7o29aVDluZGhLI8nyKM7QZaXVmOaPUtSDNkttif_Xvb7Zx-9v8Mwc1tBp4oJsGYc16TIVC1cPCFUE9ipzGG4Fg","encrypted_tracking":"AZbvjyUpupob1VtQLhNZUUKFRZchyXR7JDX_BYwNHgx42ZGK82PgCe7AX2HIkzES5s3hxVqKg8Pqp5Aorqux9ZkZTltDUg5JGwtiJ6OmXaK6WZ-IkG5kh84C0BxxmjIHsUxqsHxOPhGH2Bx4Sx6qPQ3OGFGa2V4gQiPI6gaJJEiNOoWcZU7TQxcXWzsFvME856s_6rBZiLeboOiG9iesr1wN2DUvZc9pDCnhN_7-0hSezee2F7JCEhLnO4L3e_c1KV-6yjUEAkjNKwYeoJP8R96UqJie0vuHd-dInVYd12pMbyX-vj7vXwoYLs_EEoNKERwFmPeXup62Dw9R2pjKb9BRm73Lh4E0kL7x8h3IE5eiXOOk8wHAbyfqrgKtJoO1Q0u7gCZLATvW-Lt0J9MNclptObAPtyPxKRGNebQ1g3kh0ZhaOSZCqd7q3ikbZs9yjS0NC-LdVz1_dONBnSTbs2eyrXwvbWCuuI6zoH6XIUssglCx0wqAluGTWOVUYhCig0FcmOKVJhF-RVL62wXuw8crkrcaRlukD0dpEznwICFO-