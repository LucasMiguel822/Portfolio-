otos e infos completas em nosso site, LINK na BIO.\n___________\n\nVia Bella, h\u00e1 28 anos no mercado!\nO carro deixa com a gente.\n___________\n#suv #luxurycars #cars #carspotting #landrover #rangerover #offroad #adventure #exoticcars #carporn #luxury #seminovos #luxo #carro #sportscar #autobiography #velar"},"__isNode":"Video"}}],"short_form_video_context":{"play_count_reduced":"989","playback_video":{"viewer_autoplay_setting":"default_autoplay","warning_screen_renderer":null,"id":"1971725033616149","image":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t51.71878-10\/545349609_810132341358444_2367943904559069588_n.jpg?stp=dst-jpg_s960x960_tt6&_nc_cat=109&ccb=1-7&_nc_sid=c44d43&_nc_ohc=4CQiOeukv2EQ7kNvwEc4t4N&_nc_oc=Adr2IEQfElD4bWGK8fA9NwG6eVyi9NFpDsUwxvqossWKw0t64t8i08hNtkd9Z0635vg&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfyIN6HqZXBHWctitG7v_wNs79d9d9koOi2oAzgjYwj7-g&oe=69C9DA07"}},"video_owner":{"__typename":"User","gender":"NEUTER","is_verified":false,"name":"Via Bella Ve\u00edculos","id":"100064405340960"}},"__isNode":"Story","id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxOTcxNzI1MDMzNjE2MTQ5"}},"cursor":null},{"node":{"__typename":"VideoHomeFeedUnitSectionComponent","feed_unit":{"__typename":"Story","attachments":[{"media":{"__typename":"Video","image":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t51.82787-10\/540009145_18524638786009372_3341916785383419510_n.jpg?stp=dst-jpg_p206x206_tt6&_nc_cat=111&ccb=1-7&_nc_sid=c44d43&_nc_ohc=4M72Ao_kXMsQ7kNvwE-Y1iL&_nc_oc=Adp8KN4hCufhE4wdYm8qWlFMUfbK7YpTKt7AiTjQisznWdai-K9QlbQYvCDy8UUz1gc&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfyqO4OGIVqSZnEK6P2yT2CiZ1GMgzqlz6seEeNsX5471Q&oe=69C9B402"},"is_video_broadcast":false,"has_viewer_watched_show_video":false,"id":"1468543360856479","is_live_streaming":false,"owner":{"__typename":"User","id":"100064405340960","name":"Via Bella Ve\u00edculos","profile_picture":{"uri":"https:\/\/