e&_nc_ohc=22Ep65NKXYYQ7kNvwEMoWhG&_nc_oc=AdpaEMqRNbNTderwYtxpzoALGR9VWNHqgTGRNalBkdCS5aVUgff84Ja4oFHrzeipL7s&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfzOBPrYxAKzvdrqOMs6Icq93TZBgYbhuI131MYllI3J8A&oe=69C9B700"},"is_video_broadcast":false,"has_viewer_watched_show_video":false,"id":"924047603684660","is_live_streaming":false,"owner":{"__typename":"User","id":"100064405340960","name":"Via Bella Ve\u00edculos","gender":"NEUTER","__isActor":"User","profile_picture":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t39.30808-1\/252343281_6621399317900969_3803204123193148195_n.png?stp=cp0_dst-png_s50x50&_nc_cat=107&ccb=1-7&_nc_sid=2d3e12&_nc_ohc=WBHNRYO4cOAQ7kNvwEdx5Gx&_nc_oc=Ado2JKQr6JXm4CV1xpk5rrKDr-95zLqE7akZARWAe_3cSSiWn7BAh-Q8UWppr4IhOc8&_nc_zt=24&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_Afytxhtd25I2aNRQmPjDRTvzT46TAkLo17iNmKVeJrbyjQ&oe=69C9D311"}},"canonical_uri_with_fallback":"https:\/\/www.facebook.com\/viabellaveiculos\/videos\/dupla-mais-do-que-especial-de-shelby-gt500-prestando-homenagem-ao-lend\u0025C3\u0025A1rio-shelb\/924047603684660\/","cix_screen":null,"broadcast_status":null,"video_thumbnail_overlays_renderer":{"__typename":"VideoHomeVideoThumbnailOverlaysDefaultRenderer","video":{"has_viewer_watched_show_video":false,"playable_duration_in_ms":29116,"viewer_last_play_position_ms":null,"broadcast_status":null,"playable_duration":30,"id":"924047603684660","product_tags":[]},"__module_operation_CometVideoHomeVideoThumbnail_video":{"__dr":"CometVideoHomeVideoThumbnailDefaultOverlays_video$normalization.graphql"},"__module_component_CometVideoHomeVideoThumbnail_video":{"__dr":"CometVideoHomeVideoThumbnailDefaultOverlays.react"}},"name":"","savable_description":{"text":"Dupla mais do que especial de Shelby GT500 \ud83d\udd25\ud83d\udd25\n\nPrestando homenagem ao lend\u00e1rio Shelby GT500 original de 1967, a edi\u00e7\u00e3o limitada Heritage Edition de 2022 chega com a exclusiva pintura em Brittany Blue e faixas em branco Wimbledon \u2014 uma combina\u00e7\u00e3o que resgata toda a eleg\u00e2ncia cl\u00e1ssica do \u00edcone americano.\n\nDo outro lado da dupla, o Shelby GT500 em Azul Ford Performance com faixas Black Piano tem nome pr\u00f3prio: ALPHA SNAKE. Este exemplar conta com o pacote Z\/1150 by \u0040palmbeachdyno, que inclui polia menor para o supercharger, bicos injetores de alta vaz\u00e3o, cold air intake, coletor de escape Ford Performance e escapamento Borla Atak. Nos pneus, Toyo 325\/30 na traseira e 315\/30 na dianteira completam o conjunto.\n\nUma prepara\u00e7\u00e3o feita e assinada pelos amigos do \u0040gv28br gerando n\u00fameros surreais de pot\u00eancia: 1.140cv e e 118kgfm de torque!\n\nThe Alpha Snake:\n\nR$ 1.380.000,00\n\n*Para mais infos, acesse nosso site ou consulte-nos.\n_______________________________\n\nVia Bella, h\u00e1 29 anos no mercado!\nO carro deixa com a gente.\n_______________________________\n#shelby #gt500 #mustang #carporn #supercar"},"__isNode":"Video","creation_story":{"click_tracking_linkshim_cb":"AT4QsuKrC6i6giscKmiF3e-lUHNMXpTfZ47IPMHJHt-07dXwhh1IH-9XrGmLbHqJVEWfEnaltRdPd6loJrqkRsWBVGXhJHemM9LYgwEVey3OJ8f7X0hEQnntN34vhIi3pbt9QgPsRW2kwHT3etGlTLW3M4GMVCNxEx4OME6kQYxeYi18qvH9","encrypted_click_tracking":"AZYOVbvJchoFScouLD_wUYUkjpnsPJVIiYOcFPKo_ilG1uf5hY0tkb9adksO1KhISn3Mn8DJ8OW8Lqpg6Js9GCIxd8goxLUvxogD3OLqLsSHLMY1Ljq7eKkn-kx04erKPu2Vz8sCOuPBKTVmSxU00WdHrwhzO__cpSDiBRysXLVN-g","encrypted_tracking":"AZYX4bxg91DhsP5blmTWA5xo-qJyiCUjS7Md2xi364I8_qxpROcAqyFmaI-IwkR0DHFBZ_lKwerRYMTB7bq9-yt64lv4FR1-kesMzgjQuadq9uWWmnl7hIxVwpo57hJqW3qJdrPJTJWc_EFrWzhnLZBaCO_RQydwD8tEicBMyPiagPRLGbawl5EK4wokjcoNgoz4zd-JoOPv3cj8tc2TxIl3nZZJsOPxhOh072Xt1KGgPo37qIXbvqzIhyTdXefyuAz82duypOXasDIYPawU21sWGCadELeP0gSIptyBB2noboU8EGb2zfjlv3rdjEWgmRUYyJxpeO4U32ZQThQhO3BKkYq9VpxesJAlZKBrKz1FPWn2dyOCO5955V23O19RGqehWhuuouBMYmshofvVqzqqeR1dGc6tHI_IlNkDBBU6c-Sfr6D9PlOFMYXfU8ty8EvSQpvOAcm8SsDVI39FrnvLapoQwfPhQinkLC2u7PmuqwYa2NaTn5