u00e2nsito em trilha sonora\ne rotina em prazer.\n\nPorsche 912 Turbo Cabriolet 2024\n\nImpec\u00e1vel,  com apenas 1.960Km!\n\nGarantia estendida at\u00e9 Novembro e pacote de revis\u00f5es pagas (2 pr\u00f3ximas ou 45 mil km )\n\nR$ 1.480.000\n\n*Fotos e infos completas em nosso site, LINK na BIO.\n\n_______________________________\n\nVia Bella, h\u00e1 29 anos no mercado!\nO carro deixa com a gente.\n_______________________________\n#porsche #911 #supercar #carspotting #carporn","delight_ranges":[],"image_ranges":[],"inline_style_ranges":[],"aggregated_ranges":[],"ranges":[{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/porsche?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/porsche","__isNode":"Hashtag","id":"459153237491470"},"entity_is_weak_reference":false,"length":8,"offset":510},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/supercar?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/supercar","__isNode":"Hashtag","id":"577718992238257"},"entity_is_weak_reference":false,"length":9,"offset":524},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/carspotting?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/carspotting","__isNode":"Hashtag","id":"564636930222376"},"entity_is_weak_reference":false,"length":12,"offset":534},{"entity":{"__typename":"Hashtag","__isEntity":"Hashtag","url":"https:\/\/www.facebook.com\/hashtag\/carporn?__eep__=6","mobileUrl":"https:\/\/m.facebook.com\/hashtag\/carporn","__isNode":"Hashtag","id":"495529730503497"},"entity_is_weak_reference":false,"length":8,"offset":547}],"color_ranges":[]},"id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxMTYxNzMxMjEyNzA3MTM4"},"__module_operation_CometTahoeVideoContextSectionBody_video":{"__dr":"CometTahoeVideoDefaultMessageRenderingStrategy_textWithEntities$normalization.graphql"},"__module_component_CometTahoeVideoContextSecti