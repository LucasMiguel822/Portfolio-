064405340960"}],"id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxNDQ2NDIzNDkzMDkyNjMw"},"feedback":{"viewer_feedback_reaction_info":null,"id":"ZmVlZGJhY2s6MTIxMDYxODExNDQyODM1NQ==","top_reactions":{"edges":[{"visible_in_bling_bar":true,"node":{"id":"1635855486666999","localized_name":"Curtir"},"i18n_reaction_count":"3","reaction_count":3},{"visible_in_bling_bar":true,"node":{"id":"1678524932434102","localized_name":"Amei"},"i18n_reaction_count":"1","reaction_count":1}]},"i18n_reaction_count":"4","important_reactors":{"nodes":[]},"reaction_count":{"count":4},"reaction_display_config":{"reaction_display_strategy":"NONE"},"viewer_actor":null},"play_count":484,"created_time":1759235312,"savable_title":{"text":"\u00c0s vezes basta um olhar para despertar um sonho. O Mustang Mach 1 1969 representa exatamente isso: um cl\u00e1ssico que marcou os anos 60 e 70 e at\u00e9 hoje segue como objeto de desejo dos apaixonados por carros.\n\nO ano de 1969 trouxe uma reestiliza\u00e7\u00e3o marcante para a linha Mustang. A carroceria fastback ganhou propor\u00e7\u00f5es mais robustas, far\u00f3is qu\u00e1druplos e uma presen\u00e7a ainda mais musculosa, transformando o Mach 1 em um verdadeiro \u00edcone. Neste exemplar, o motor 5.8 V8 351 injetado, aliado ao c\u00e2mbio manual, entrega a experi\u00eancia mais purista que um muscle car americano pode oferecer.\n\nAl\u00e9m deste powertrain, este exemplar tem algo ainda mais especial: foi importado 0 km para o Brasil, sem passar pelas condi\u00e7\u00f5es clim\u00e1ticas ou estradas salgadas dos EUA. Mant\u00e9m caracter\u00edsticas originais de \u00e9poca, incluindo as rodas Magnum, pneus Cooper Cobra e o louver traseiro (persiana), que refor\u00e7a o visual agressivo e aut\u00eantico do fastback.\n\nNa Via Bella temos dispon\u00edvel este cl\u00e1ssico da Ford que transcende gera\u00e7\u00f5es e desperta o entusiasta: um Mustang Mach 1 Fastback 1969, raro e hist\u00f3rico.\n\nR$ 750.000,00\n\n*Consulte-nos para mais informa\u00e7\u00f5es.\n\nFotos completas em nosso site, LINK na BIO.\n\n_______________________________\n\nE A\u00cd, GOSTOU?\nENTRA EM CONTATO COM A GENTE!\n_______________________________\n\n54 3027-7700 \/ 54 9 9959-7700\nAcesse: www.viabella.com.br\nBaixe o Aplicativo Via Bella\nPlay Store e Apple Store\n_______________________________\n\nVia Bella, h\u00e1 28 anos no mercado!\nO carro deixa com a gente.\n_______________________________\n#americanmuscle#musclecar#mustang#mustangfastback#fastback#americancar#route66#fordmustang#classiccars#carrosantigos#mustangclub#exoticcars"},"__isNode":"Video"}}],"short_form_video_context":{"play_count_reduced":"484","playback_video":{"viewer_autoplay_setting":"default_autoplay","warning_screen_renderer":null,"id":"1446423493092630","image":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t51.71878-10\/556827686_1299966648259061_9167631929813885921_n.jpg?stp=dst-jpg_s960x960_tt6&_nc_cat=101&ccb=1-7&_nc_sid=c44d43&_nc_ohc=IYbiR7hvz5wQ7kNvwGZ71SI&_nc_oc=AdoaDZRoW5YTIDWd3IfHcKORI7VXZsT4bwForLAy4hNwW-kgtUgNBGgNvB6t3omLNdg&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_Afxl7E16pd-8mH_PGXpQ-X8g4_BQ7cf_lNRhoTaV5BZOEA&oe=69C9D893"}},"video_owner":{"__typename":"User","gender":"NEUTER","is_verified":false,"name":"Via Bella Ve\u00edculos","id":"100064405340960"}},"__isNode":"Story","id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxNDQ2NDIzNDkzMDkyNjMw"}},"cursor":null},{"node":{"__typename":"VideoHomeFeedUnitSectionComponent","feed_unit":{"__typename":"Story","attachments":[{"media":{"__typename":"Video","image":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t51.71878-10\/550023455_1491606692288487_3586771489161435114_n.jpg?stp=dst-jpg_p206x206_tt6&_nc_cat=111&ccb=1-7&_nc_sid=c44d43&_nc_ohc=971X7aPgJpQQ7kNvwEtexor&_nc_oc=AdqsiBad5eF5kYN_t_OeENWcQdMNZNYe1ymbtdACysw58mvrCGqbEuVrq6RI3C3og_8&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfzdqXSLmM_hzySoXKENjOEzusMQZ56rDOP0lv3_yRJUeA&oe=69