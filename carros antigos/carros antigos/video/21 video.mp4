"important_reactors":{"nodes":[]},"reaction_count":{"count":61},"reaction_display_config":{"reaction_display_strategy":"NONE"},"viewer_actor":null},"play_count":5381,"created_time":1754222705,"savable_title":{"text":"O Ford Mustang GTD \u00e9 um supercarro motor V8 de 5,2 l, transmiss\u00e3o de dupla embraiagem de 8 velocidades e pot\u00eancia at\u00e9 800 cavalos. Concebido para a estrada e para a pista, apresenta uma suspens\u00e3o inspirada nas corridas, um spoiler traseiro aerodin\u00e2mico que controla a distribui\u00e7\u00e3o de peso de quase 50\/50 para um comportamento e performance excecionais.\n\nConfira agora as primeiras impress\u00f5es de Max Verstappen ao dirigir o superesportivo!\n\nE voc\u00ea, curtiu a novidade? \ud83d\udd25\n\n_______________________________\n\nVia Bella, h\u00e1 28 anos no mercado!\nO carro deixa com a gente.\n_______________________________\n#ford #mustang #mustangtd #fordperformance #f1 #supercar #verstappen #carspotting #supercar #musclecar #race #racing #carporn #exoticcars #formula1"},"__isNode":"Video"}}],"short_form_video_context":{"play_count_reduced":"5,3\u00a0mil","playback_video":{"viewer_autoplay_setting":"default_autoplay","warning_screen_renderer":null,"id":"1053540313598869","image":{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\/t51.71878-10\/506390393_764352039882144_28743462589608079_n.jpg?stp=dst-jpg_s960x960_tt6&_nc_cat=102&ccb=1-7&_nc_sid=c44d43&_nc_ohc=OnQw-kAY4pAQ7kNvwFRWZ-C&_nc_oc=Adqq3_Ii_ObK8m6DXAWs1B7zP360OpZlMYQnXIzRfZnkTc1434p9CeVo8yZS6mwQrAU&_nc_zt=23&_nc_ht=scontent.fgru6-1.fna&_nc_gid=APG3J_QVXb0LTBETWoWujg&_nc_ss=7a30f&oh=00_AfzIgkCmbVeU1tyVVq83yBbHmj5ue6poYZN0Cx5gGLg0_Q&oe=69C9BE9A"}},"video_owner":{"__typename":"User","gender":"NEUTER","is_verified":false,"name":"Via Bella Ve\u00edculos","id":"100064405340960"}},"__isNode":"Story","id":"UzpfSTEwMDA2NDQwNTM0MDk2MDpWSzoxMDUzNTQwMzEzNTk4ODY5"}},"cursor":null},"extensions":{"prefetch_uris_v2":[{"uri":"https:\/\/scontent.fgru6-1.fna.fbcdn.net\/v\